.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 28%, rgba(204,214,255,.85), transparent 30%),
    linear-gradient(135deg, #fffaf0 0%, #eef6ff 46%, #f5edff 100%);
  color: #56518d;
}

.top {
  position: absolute;
  z-index: 3;
  top: calc(env(safe-area-inset-top) + 22px);
  left: 30px;
  display: flex;
  align-items: center;
  gap: 16px;
}

.back {
  width: 44px;
  height: 44px;
  padding: 0;
  border-radius: 50%;
  color: #817dd0;
  background: rgba(255,255,255,.62);
}

.title {
  font-size: 26px;
  color: #615ca3;
  font-weight: 650;
}

.sub {
  margin-top: 4px;
  font-size: 13px;
  color: rgba(97,92,163,.62);
}

.orb {
  position: absolute;
  left: 50%;
  top: 47%;
  width: 48vw;
  height: 48vw;
  max-width: 580px;
  max-height: 580px;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background:
    radial-gradient(circle at 34% 26%, rgba(255,255,255,.9), transparent 20%),
    radial-gradient(circle at 52% 56%, rgba(148,151,226,.58), rgba(202,213,255,.4) 48%, rgba(255,231,226,.52) 80%);
  box-shadow: 0 40px 110px rgba(121,132,202,.24), inset 22px 18px 52px rgba(255,255,255,.42);
  opacity: .68;
}

.panel {
  position: relative;
  z-index: 2;
  width: min(620px, calc(100vw - 42px));
  margin: 15vh auto 0;
  padding: 28px;
  border-radius: 34px;
  background: rgba(255,255,255,.68);
  border: 1px solid rgba(139,136,204,.2);
  box-shadow: 0 32px 90px rgba(112,122,188,.18);
  backdrop-filter: blur(24px);
}

.frequency-card {
  display: grid;
  grid-template-columns: 64px 1fr;
  gap: 16px;
  align-items: center;
  margin-bottom: 20px;
  padding: 16px;
  border-radius: 24px;
  background: rgba(255,255,255,.56);
  border: 1px solid rgba(139,136,204,.16);
}

.frequency-icon {
  width: 64px;
  height: 64px;
  display: grid;
  place-items: center;
  border-radius: 50%;
  color: #fff;
  font-size: 28px;
  box-shadow: 0 18px 42px rgba(112,122,188,.2);
}

.frequency-title {
  color: #555095;
  font-size: 22px;
  font-weight: 650;
}

.frequency-copy {
  margin-top: 6px;
  color: #7773b7;
  font-size: 13px;
  line-height: 1.55;
}

.step {
  margin: 18px 0 12px;
  color: #736fc0;
  font-size: 13px;
  letter-spacing: .08em;
}

.step:first-child {
  margin-top: 0;
}

.grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
}

.grid.small {
  grid-template-columns: repeat(3, 1fr);
}

.signal-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.signal-chip {
  min-height: 74px;
  display: grid;
  grid-template-columns: 14px 1fr;
  gap: 10px;
  align-items: center;
  padding: 12px;
  border-radius: 18px;
  background: rgba(255,255,255,.62);
  border: 1px solid rgba(139,136,204,.18);
}

.signal-chip.active {
  background: rgba(145,139,230,.16);
  border-color: rgba(145,139,230,.38);
  box-shadow: 0 16px 34px rgba(121,127,221,.14);
}

.signal-dot {
  width: 14px;
  height: 42px;
  border-radius: 999px;
}

.signal-name {
  color: #555095;
  font-size: 15px;
  font-weight: 650;
}

.signal-text {
  margin-top: 4px;
  color: #7773b7;
  font-size: 11px;
  line-height: 1.35;
}

.chip {
  min-height: 58px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border-radius: 18px;
  background: rgba(255,255,255,.62);
  border: 1px solid rgba(139,136,204,.18);
  color: #6c68aa;
  font-size: 15px;
}

.chip text {
  font-size: 22px;
}

.chip.active {
  color: #fff;
  background: linear-gradient(135deg, #9c98eb, #8d91de);
  box-shadow: 0 16px 34px rgba(121,127,221,.22);
}

.slider-row {
  display: grid;
  grid-template-columns: 28px 1fr 28px;
  align-items: center;
  gap: 12px;
  color: #7773b7;
}

textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 96px;
  padding: 16px;
  border-radius: 20px;
  color: #56518d;
  background: rgba(255,255,255,.68);
  border: 1px solid rgba(139,136,204,.18);
}

.primary {
  margin-top: 24px;
  width: 100%;
  height: 56px;
  border-radius: 18px;
  color: #fff;
  background: linear-gradient(135deg, #9c98eb, #8d91de);
}

@media (max-width: 760px) {
  .top { left: 18px; }
  .panel {
    margin-top: 13vh;
    padding: 22px;
  }
  .grid,
  .grid.small {
    grid-template-columns: repeat(2, 1fr);
  }
  .signal-grid {
    grid-template-columns: 1fr;
  }
  .frequency-card {
    grid-template-columns: 52px 1fr;
    padding: 14px;
  }
  .frequency-icon {
    width: 52px;
    height: 52px;
    font-size: 24px;
  }
  .frequency-title { font-size: 18px; }
  .orb {
    width: 88vw;
    height: 88vw;
  }
}
