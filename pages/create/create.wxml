<view class="page">
  <view class="nav">RESONANCE LOCK / MUSIC / PARTICLE / MEMORY MAP</view>
  <view class="ai-pill">{{memory.matchType.label}} · {{person.city}} · {{memory.exportMemory.format}}</view>

  <canvas id="particleCanvas" type="2d" class="particle"></canvas>

  <view class="memory-card">
    <view class="label">RESONANCE LOCKED</view>
    <view class="lock-line">{{memory.lockLine}}</view>
    <view class="poem">{{memory.posterLine}}</view>
    <view class="caption">{{memory.title}}</view>

    <view class="creation-grid">
      <view class="creation-box">
        <view class="brief-label">专属音乐</view>
        <view class="brief-text">{{memory.music}}</view>
      </view>
      <view class="creation-box">
        <view class="brief-label">粒子画面</view>
        <view class="brief-text">{{memory.particle.description}}</view>
      </view>
    </view>

    <view class="poster-preview">
      <view class="poster-top">{{memory.poster.brand}}</view>
      <view class="poster-title">{{memory.poster.title}}</view>
      <view class="poster-line">{{memory.poster.line}}</view>
      <view class="poster-meta">{{memory.poster.route}} / {{memory.poster.signal}} / {{memory.exportMemory.duration}}</view>
    </view>

    <view class="mix-steps">
      <view class="step-pill" wx:for="{{memory.steps}}" wx:key="*this">{{index + 1}} / {{item}}</view>
    </view>

    <view class="atlas">
      <view>
        <view class="brief-label">今日情绪记忆地图</view>
        <view class="atlas-line">{{memory.atlasPoint.line}}</view>
      </view>
      <view class="atlas-map">
        <view wx:for="{{atlasLights}}" wx:key="index" class="atlas-point {{item.active ? 'active' : ''}}" style="left: {{item.left}}%;"></view>
      </view>
    </view>
  </view>

  <view class="player">
    <button class="play" bindtap="togglePlay">{{playing ? 'Ⅱ' : '▶'}}</button>
    <view class="bars">
      <view wx:for="{{bars}}" wx:key="index" style="height: {{item}}px;"></view>
    </view>
    <view class="save" bindtap="saveMemory">保存</view>
  </view>
  <view class="time-row">
    <text>{{playing ? memory.exportMemory.duration : '00:03'}}</text>
    <button bindtap="exportMp4Memory">{{exported ? '已生成预览' : '生成 MP4 记忆'}}</button>
  </view>

  <view class="actions">
    <button open-type="share">分享卡片</button>
    <button bindtap="rematch">重新匹配</button>
    <button bindtap="home">返回地球</button>
  </view>
</view>
