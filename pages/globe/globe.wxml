<view class="page">
  <view class="flow-line line-a"></view>
  <view class="flow-line line-b"></view>

  <view class="top">
    <button class="back" bindtap="goBack">‹</button>
    <view>
      <view class="title">进入 Mood Earth</view>
      <view class="sub">地球正在定位你此刻的情绪坐标</view>
    </view>
  </view>

  <view class="orbit orbit-a"></view>
  <view class="orbit orbit-b"></view>
  <canvas
    id="globeCanvas"
    type="2d"
    class="globe"
    bindtouchstart="onTouchStart"
    bindtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
    bindtouchcancel="onTouchEnd"
  ></canvas>

  <view class="city city-a">London<text>温暖回声</text></view>
  <view class="city city-b">Paris<text>期待轨道</text></view>
  <view class="city city-c">Tokyo<text>蓝色低频</text></view>
  <view class="city city-d">Chongqing<text>夜间波纹</text></view>

  <view class="card">
    <view class="card-title">Current Position</view>
    <view class="card-cn">匿名定位 / 情绪入口</view>
    <view class="image"></view>
    <view class="label">当前地球情绪天气</view>
    <view class="mood">○ Floating <text>等待校准</text></view>
    <view class="label">下一步</view>
    <view class="quote">不用回答一组问题，只需要把光、声音和强度慢慢调到真实的位置。</view>
    <button class="primary" bindtap="startSync">开始情绪校准</button>
  </view>
</view>
