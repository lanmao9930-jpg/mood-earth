.page {
  min-height: 100vh;
  overflow: hidden;
  position: relative;
  background:
    radial-gradient(circle at 18% 16%, rgba(255,255,255,.95), transparent 30%),
    radial-gradient(circle at 60% 58%, rgba(255,205,210,.26), transparent 38%),
    linear-gradient(135deg, #fff8eb 0%, #eaf6ff 42%, #f3edff 100%);
  color: #56518d;
}

.flow-line {
  position: absolute;
  height: 1px;
  border-radius: 999px;
  background: linear-gradient(90deg, transparent, rgba(126,139,219,.34), rgba(255,188,182,.28), transparent);
  box-shadow: 0 0 26px rgba(126,139,219,.18);
  animation: floatLine 8s ease-in-out infinite;
}

.line-a { width: 58vw; left: 7vw; top: 22vh; transform: rotate(-17deg); }
.line-b { width: 62vw; right: 0; top: 68vh; transform: rotate(15deg); animation-delay: -3s; }

@keyframes floatLine {
  0%, 100% { opacity: .38; margin-top: 0; }
  50% { opacity: .95; margin-top: 18px; }
}

.top {
  position: absolute;
  z-index: 4;
  top: calc(env(safe-area-inset-top) + 22px);
  left: 30px;
  display: flex;
  align-items: center;
  gap: 16px;
}

.back {
  width: 44px;
  height: 44px;
  padding: 0;
  border-radius: 50%;
  color: #817dd0;
  background: rgba(255,255,255,.62);
}

.title {
  font-size: 24px;
  color: #615ca3;
  font-weight: 650;
}

.sub {
  margin-top: 4px;
  font-size: 13px;
  color: rgba(97,92,163,.62);
}

.globe {
  position: absolute;
  left: 50%;
  top: 50%;
  width: min(62vw, 700px);
  height: min(62vw, 700px);
  transform: translate(-54%, -48%);
  border-radius: 50%;
  filter: drop-shadow(0 36px 88px rgba(92,112,196,.32));
}

.orbit {
  position: absolute;
  left: 46%;
  top: 51%;
  width: min(68vw, 780px);
  aspect-ratio: 1.7;
  border: 1px solid rgba(144,143,213,.26);
  border-radius: 50%;
  transform: translate(-50%, -50%) rotate(-13deg);
  animation: orbitBreathe 7s ease-in-out infinite;
}

.orbit-b {
  width: min(58vw, 680px);
  transform: translate(-50%, -50%) rotate(18deg);
  opacity: .55;
  animation-delay: -2s;
}

@keyframes orbitBreathe {
  0%, 100% { opacity: .42; }
  50% { opacity: .88; }
}

.city {
  position: absolute;
  z-index: 3;
  padding: 8px 14px;
  border-radius: 13px;
  background: rgba(255,255,255,.72);
  border: 1px solid rgba(139,136,204,.18);
  box-shadow: 0 12px 38px rgba(105,116,190,.14);
  color: #57528f;
  font-size: 13px;
  text-align: center;
  backdrop-filter: blur(14px);
}

.city text {
  display: block;
  color: #7773b7;
  font-size: 12px;
}

.city-a { left: 45%; top: 20%; }
.city-b { left: 30%; top: 33%; }
.city-c { right: 25%; top: 45%; }
.city-d { left: 32%; bottom: 26%; }

.card {
  position: absolute;
  z-index: 5;
  right: 30px;
  top: 17vh;
  width: 258px;
  padding: 22px;
  border-radius: 28px;
  background: rgba(255,255,255,.68);
  border: 1px solid rgba(139,136,204,.24);
  box-shadow: 0 28px 80px rgba(112,122,188,.24);
  backdrop-filter: blur(22px);
}

.card-title {
  font-family: Georgia, "Times New Roman", serif;
  font-size: 32px;
  color: #4e4a92;
}

.card-cn {
  margin-top: 6px;
  color: #706bb0;
  font-size: 16px;
}

.image {
  margin-top: 16px;
  height: 94px;
  border-radius: 16px;
  background:
    linear-gradient(135deg, rgba(177,194,235,.72), rgba(255,246,224,.78)),
    repeating-linear-gradient(145deg, rgba(86,98,167,.15) 0 1px, transparent 1px 14px);
}

.label {
  margin-top: 18px;
  color: #837fbd;
  font-size: 12px;
}

.mood {
  margin-top: 8px;
  color: #8b89d7;
  font-size: 19px;
  font-weight: 650;
}

.mood text {
  margin-left: 8px;
  font-size: 14px;
  color: #7773b7;
}

.quote {
  margin-top: 8px;
  color: #545090;
  font-size: 14px;
  line-height: 1.72;
}

.primary {
  margin-top: 22px;
  width: 100%;
  height: 54px;
  border-radius: 16px;
  color: #fff;
  background: linear-gradient(135deg, #9c98eb, #8d91de);
}

@media (max-width: 760px) {
  .top { left: 18px; }
  .globe {
    width: 76vw;
    height: 76vw;
    transform: translate(-50%, -45%);
  }
  .orbit { width: 94vw; left: 50%; }
  .city { display: none; }
  .card {
    left: auto;
    right: 14px;
    top: auto;
    bottom: 82px;
    width: 184px;
    padding: 14px;
    border-radius: 22px;
  }
  .card-title { font-size: 22px; }
  .card-cn { font-size: 13px; }
  .image { height: 52px; border-radius: 12px; }
  .label { margin-top: 10px; font-size: 10px; }
  .mood { font-size: 15px; }
  .mood text { font-size: 11px; }
  .quote { font-size: 11px; line-height: 1.5; }
  .primary { margin-top: 14px; height: 42px; border-radius: 14px; font-size: 13px; }
}
