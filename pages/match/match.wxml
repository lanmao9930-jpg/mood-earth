<view class="page">
  <view class="top">
    <button class="back" bindtap="goBack">‹</button>
    <view>
      <view class="title">全球共鸣</view>
      <view class="sub">先看世界上的情绪热区，再选择想共创的人</view>
    </view>
  </view>

  <view class="earth">
    <view wx:for="{{moodMap.cities}}" wx:key="city" class="heat-dot h{{index}} {{item.active ? 'active' : ''}}">
      <view class="dot-core"></view>
      <text>{{item.city}}</text>
    </view>
  </view>
  <view class="pin p1"></view>
  <view class="pin p2"></view>
  <view class="pin p3"></view>

  <view class="signal">
    <view class="signal-title">{{signature.name}}</view>
    <view>{{signature.strength}} / {{signature.need.label}} / {{signature.signal.label}}</view>
  </view>

  <view class="heat-panel">
    <view class="heat-title">{{moodMap.headline}}</view>
    <view class="heat-sub">{{moodMap.subline}}</view>
    <view class="city-row" wx:for="{{moodMap.cities}}" wx:key="city">
      <view class="city-name">{{item.city}}</view>
      <view class="heat-track"><view class="heat-fill {{item.active ? 'active' : ''}}" style="width: {{item.heat}}%;"></view></view>
      <view class="city-meta">{{item.moodLabel}} / {{item.people}}</view>
    </view>
  </view>

  <view class="list">
    <view wx:for="{{matches}}" wx:key="id" class="match-card" data-id="{{item.id}}" bindtap="choose">
      <view class="avatar">{{item.initial}}</view>
      <view class="info">
        <view class="name">{{item.name}} <text>{{item.score}}%</text></view>
        <view class="meta">{{item.city}}, {{item.country}} / {{item.tagText}}</view>
        <view class="meta">声音画像：{{item.sound.label}} / {{item.culture}}</view>
        <view class="reason">{{item.reason}}</view>
        <view class="quote">“{{item.quote}}”</view>
      </view>
      <view class="action">共创</view>
    </view>
  </view>
</view>
